{
  "name": "@nexus/mcp-server",
  "version": "1.0.0",
  "description": "MCP (Model Context Protocol) server for Nexus CMS — enables AI agents and external tools to interact with the CMS programmatically.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nexus-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --watch dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
