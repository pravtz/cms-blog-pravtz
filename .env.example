# ─────────────────────────────────────────────────────────────────────────────
# Nexus CMS — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production

# ── JWT secrets (generate with: openssl rand -base64 64) ─────────────────────
JWT_SECRET=change_me_generate_a_random_64_char_secret
JWT_REFRESH_SECRET=change_me_generate_a_different_random_64_char_secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite: path to the data directory (mounted volume in Docker)
DATA_DIR=/data

# ── Networking ────────────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# Public URL of your blog
BLOG_URL=https://yourblog.com

# Internal URL of the admin service (used by blog for API calls)
ADMIN_URL=http://admin:3001

# ── SMTP (optional — required for email features) ─────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourblog.com

# ── AI Providers (optional — required for AI features, US-31+) ───────────────
# Stored AES-256-GCM encrypted in the database, never returned in responses.
# Configure in admin panel: Settings > AI & Quotas.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Microsoft Clarity (optional — analytics, US-34) ───────────────────────────
# CLARITY_PROJECT_ID=your_clarity_project_id

# ── Encryption key for sensitive settings (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=change_me_generate_a_random_32_char_key
